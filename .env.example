# PSALM environment template. Copy to .env (gitignored) and fill in.
# Config values can also be overridden via PSALM_* env vars (see config/settings.py),
# e.g. PSALM_TRAINING__LEARNING_RATE=0.0003

# Hugging Face (datasets + models published under qbz506/psalm-*)
HF_TOKEN=
HF_HUB_ENABLE_HF_TRANSFER=1

# Weights & Biases (experiment tracking; optional, TensorBoard is the default)
WANDB_API_KEY=
WANDB_PROJECT=psalm
WANDB_MODE=offline

# Local memory / knowledge store
PSALM_LEDGER_PATH=outputs/experiment-ledger.sqlite
PSALM_VECTOR_STORE_PATH=outputs/knowledge-store
