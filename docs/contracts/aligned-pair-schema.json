{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/SharathSPhD/PSALM/schemas/paribhasha_aligned_v1.json",
  "title": "paribhasha_aligned_v1",
  "description": "One aligned Sanskrit sentence with kāraka parse, Śabdabodha graph, and Paribhāṣā string (PSALM L2/L5).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "text",
    "karaka_parse",
    "shabdabodha_graph",
    "paribhasha_string",
    "meta"
  ],
  "properties": {
    "text": {
      "type": "string",
      "minLength": 1,
      "description": "Sanskrit surface sentence (WX or IAST; consistent per corpus)."
    },
    "karaka_parse": {
      "type": "array",
      "description": "Token–kāraka role pairs in surface order.",
      "items": {
        "type": "array",
        "minItems": 2,
        "maxItems": 2,
        "prefixItems": [
          { "type": "string" },
          { "type": "string" }
        ],
        "items": false
      }
    },
    "shabdabodha_graph": {
      "type": "object",
      "description": "Typed Śabdabodha semantic graph.",
      "additionalProperties": false,
      "required": ["nodes", "edges"],
      "properties": {
        "nodes": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "category"],
            "properties": {
              "id": { "type": "string" },
              "category": {
                "type": "string",
                "enum": [
                  "DRAVYA",
                  "GUNA",
                  "KRIYA",
                  "SAMANYA",
                  "VISESA",
                  "SAMAVAYA",
                  "ABHAVA"
                ]
              },
              "label": { "type": "string" }
            }
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["src", "dst", "sansa"],
            "properties": {
              "src": { "type": "string" },
              "dst": { "type": "string" },
              "sansa": {
                "type": "string",
                "enum": [
                  "VISAYATA",
                  "PRAKARATA",
                  "VISESYATA",
                  "AVACCHEDAKA",
                  "SAMAVAYA",
                  "SAMYOGATA"
                ]
              },
              "qualifier": { "type": "string" }
            }
          }
        }
      }
    },
    "paribhasha_string": {
      "type": "string",
      "minLength": 1,
      "description": "Canonical linearized Paribhāṣā (ASCII default per ADR-0020)."
    },
    "meta": {
      "type": "object",
      "additionalProperties": true,
      "required": ["schema_version", "source"],
      "properties": {
        "schema_version": {
          "type": "string",
          "const": "paribhasha_aligned_v1"
        },
        "source": {
          "type": "string",
          "description": "Generator or pipeline id, e.g. samsadhani, vidyut, paribhasha_synthetic."
        },
        "seed": { "type": "integer" },
        "fixture_id": { "type": "string" },
        "rule_coverage": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Fraction of Vyutpattivāda rules applied successfully."
        },
        "synthetic": {
          "type": "boolean",
          "description": "True if graph from U4 test generator, not U5 Vyutpattivāda."
        },
        "language": { "type": "string", "const": "sa" }
      }
    }
  }
}
